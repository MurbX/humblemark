# Environment for docker-compose.yml (full-stack run / Coolify deploy).
# Copy to .env and fill in. Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"

# Postgres
DATABASE_NAME=humblemark
DATABASE_USERNAME=humblemark
DATABASE_PASSWORD=

# Strapi secrets (APP_KEYS is four comma-separated values)
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=
JWT_SECRET=

# Public URL of the CMS as browsers will reach it
PUBLIC_CMS_URL=http://localhost:1337

# Optional: Strapi API token used by the storefront for non-public content
STRAPI_API_TOKEN=
