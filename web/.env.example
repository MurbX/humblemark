# Copy this file to .env.local for local development.

# Public URL of the Strapi CMS (used by the browser and next/image).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Optional: internal URL for server-side fetches (e.g. Docker network hostname).
# Falls back to NEXT_PUBLIC_STRAPI_URL when unset.
# STRAPI_INTERNAL_URL=http://cms:1337

# Optional: Strapi API token for reading non-public content.
# STRAPI_API_TOKEN=
